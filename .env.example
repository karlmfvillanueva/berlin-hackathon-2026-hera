# Hera API key — get from https://app.hera.video/
HERA_API_KEY=your_hera_api_key_here

# Vertex AI — drives BOTH the editorial classifier (gemini-2.5-pro) AND the
# photo outpainter (gemini-2.5-flash-image). Auth is Application Default
# Credentials (no API key in env). Run once locally:
#   gcloud auth application-default login
#   gcloud auth application-default set-quota-project <project-id>
# On Railway: paste the full service-account JSON as a single-line value into
#   GOOGLE_APPLICATION_CREDENTIALS_JSON. The container entrypoint writes it to
#   /tmp/gcp-key.json and exports GOOGLE_APPLICATION_CREDENTIALS for you.
GCP_PROJECT=
GCP_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS_JSON=  # Railway only — full service-account JSON
# Optional model overrides — drop in 3.x preview IDs when the project gets allowlisted.
# GEMINI_CLASSIFIER_MODEL=gemini-3.1-pro-preview
# GEMINI_OUTPAINT_MODEL=gemini-3.1-flash-image-preview

# Supabase (Phase 2 video persistence + agent beliefs + outpaint storage bucket).
# When unset, the backend runs in stateless mode, the classifier sees no beliefs,
# and the outpaint toggle is a no-op (returns original URLs).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Supabase Auth (Phase 3 — end-user auth + YouTube + dashboard).
# JWT_SECRET: Supabase Dashboard → Settings → API → JWT Secret. Used to validate
# tokens server-side. ANON_KEY is exposed to the browser via VITE_SUPABASE_*.
SUPABASE_JWT_SECRET=
# Set to "false" in dev to bypass auth and run with a synthetic user; production
# (Railway) leaves this unset so REQUIRE_AUTH defaults to "true".
REQUIRE_AUTH=false

# Frontend Supabase wiring (Vite reads these into the bundle — never put a service key here).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google OAuth client for YouTube auto-deploy. SEPARATE from any Vertex/ADC creds.
# Create in Google Cloud Console → Credentials → "OAuth 2.0 Client IDs" → Web app.
# Authorized redirect URIs must include http://localhost:8000/api/youtube/callback
# and your Railway prod URL + /api/youtube/callback.
GOOGLE_OAUTH_CLIENT_ID_YOUTUBE=
GOOGLE_OAUTH_CLIENT_SECRET_YOUTUBE=

# Public base URL the backend serves under (used to build the OAuth callback).
# Local: http://localhost:8000. Railway: https://<your-app>.up.railway.app.
BASE_URL=http://localhost:8000

# Phase 2 live scraper (B-07). When false, only fixture URLs work in /api/listing.
ENABLE_LIVE_SCRAPE=false

# ScraperAPI fallback. Direct Playwright from Railway is blocked by Airbnb's
# Cloudflare/PerimeterX layer; ScraperAPI's residential-proxy pool gets through.
# Free tier = 1000 credits/month, but Airbnb requires ultra_premium=true (30
# credits/req) so plan ~33 fallback scrapes/month. Sign up at scraperapi.com,
# paste the API key here. Leave unset to disable the fallback.
SCRAPERAPI_KEY=

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Frontend (Vite reads VITE_*)
VITE_BACKEND_URL=http://127.0.0.1:8000
