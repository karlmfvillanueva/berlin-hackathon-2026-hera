# Hera API key — get from https://app.hera.video/
HERA_API_KEY=your_hera_api_key_here

# Gemini API key (used by the agent classifier — Gemini 3.1 Pro)
GEMINI_API_KEY=your_gemini_api_key_here

# Nanobanana / fal.ai key (Phase 2 outpaint toggle). Without it the outpainter
# is a no-op and returns the original landscape URLs.
NANOBANANA_API_KEY=your_fal_ai_key_here

# Supabase (Phase 2 video persistence + agent beliefs). When unset, the backend
# runs in stateless mode and the classifier sees no beliefs.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Phase 2 live scraper (B-07). When false, only fixture URLs work in /api/listing.
ENABLE_LIVE_SCRAPE=false

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Frontend (Vite reads VITE_*)
VITE_BACKEND_URL=http://127.0.0.1:8000
