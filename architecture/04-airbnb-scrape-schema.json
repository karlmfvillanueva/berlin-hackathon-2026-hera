          },
          "source": "AVAILABILITY_CALENDAR_DEFAULT.calendarMonths",
          "cost": "free",
          "notes": "Initial render covers ~2 months. Additional months load via paginated GraphQL (StaysPdpAvailabilityCalendar)."
        },
        "min_nights": {
          "type": "integer",
          "example": 1,
