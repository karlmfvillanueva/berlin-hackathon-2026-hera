  "what_we_can_not_get": {
    "description": "Fields that are NOT reachable via public-PDP scraping.",
    "items": [
      {"field": "exact_street_address", "reason": "Disclosed only after booking confirmation."},
      {"field": "host_phone_email", "reason": "All comms forced through in-platform messaging."},
      {"field": "host_message_inbox", "reason": "Requires authenticated session."},
      {"field": "true_dynamic_pricing_curve", "reason": "Public PDP shows current price for current dates only. Historical pricing not surfaced."},
      {"field": "guest_identities_in_reviews", "reason": "Reviewer last names, emails, exact location withheld."},
      {"field": "host_payout_currency_or_payment_settings", "reason": "Private to host."},
      {"field": "internal_quality_score_raw", "reason": "Only the percentile bucket is shown ('top 1 %')."}
    ]
  },

  "implementation_hints": {
    "extraction_strategy": {
      "step_1_navigate": "Playwright navigate to https://www.airbnb.de/rooms/<id>?check_in=YYYY-MM-DD&check_out=YYYY-MM-DD&adults=N&locale=de (or en).",
      "step_2_grab_blob": "page.evaluate(() => document.getElementById('data-deferred-state-0').textContent). The result is a JSON string -> JSON.parse -> JSON.parse again (it's double-encoded as { niobeClientData: [[queryKey, payload]] }).",
      "step_3_walk_sections": "payload.data.presentation.stayProductDetailPage.sections.sections is a list of { sectionId, sectionComponentType, section }. Index by sectionId.",
      "step_4_walk_node": "payload.data.node.pdpPresentation has flattened fields (descriptions, overview, mediaTour, businessDetails, quality, sharingConfig).",
      "step_5_optional_modals": "For price breakdown click button matching /preisaufschl(ü|u)sselung/i; for full reviews click 'Alle ... Bewertungen anzeigen' then scroll a [role=dialog] container until no new reviewer cards appear.",
      "step_6_fallback_dom": "If a section returns null (Airbnb A/B-tests change schemas), fall back to scraping the visible DOM via document.querySelector('[data-section-id=\"...\"]').innerText."
    },
    "robustness_warnings": [
      "Schema is unstable. Fields/section IDs change in Airbnb releases — wrap each extraction in a try/except and store a snapshot of the raw blob alongside parsed output.",
      "Locale changes labels but keeps IDs/enums. For multi-language agent prompts, prefer the enum (e.g. categoryType='LOCATION') over the localized label ('Lage').",
      "Image URLs lack ?im_w=... — the bare base_url returns the original. For thumbnails use ?im_w=240/720/1080.",
      "Airbnb has bot detection (datadome). Playwright with stealth headers + residential IP works; raw curl usually doesn't.",
      "Be polite: cap concurrency, randomize delays, identify in User-Agent, respect robots.txt for the agent's actual use case."
    ]
  }
}
