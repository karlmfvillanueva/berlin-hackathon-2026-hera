          "notes": "Rounded display value for the URL's check_in/check_out range."
        },
        "price_breakdown": {
          "type": "object",
          "example": {
            "nights": 2,
            "price_per_night": "84,68 €",
            "subtotal": "169,36 €",
            "taxes": "22,10 €",
            "total": "191,46 €",
            "due_today": "0 €"
          },
          "source": "Modal 'Detaillierte Preisanzeige' (open via 'Preisaufschlüsselung anzeigen' link)",
          "cost": "modal_click",
          "notes": "Includes service fees, taxes, cleaning fees when present."
        },
        "currency": {
          "type": "string (ISO 4217)",
